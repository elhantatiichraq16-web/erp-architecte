{% extends 'base.html.twig' %}

{% block title %}Clients{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active">Clients</li>
{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_client_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Nouveau client
    </a>
{% endblock %}

{% block body %}
<div class="card rounded-4 shadow-sm">
    <div class="card-header bg-white border-bottom py-3">
        <form method="GET" action="{{ path('app_client_index') }}" class="d-flex gap-2">
            <div class="input-group" style="max-width: 360px;">
                <span class="input-group-text bg-light border-end-0">
                    <i class="bi bi-search text-muted"></i>
                </span>
                <input type="text" name="search" class="form-control border-start-0"
                       placeholder="Rechercher un client…" value="{{ search }}">
            </div>
            <button type="submit" class="btn btn-outline-secondary">Rechercher</button>
            {% if search %}
                <a href="{{ path('app_client_index') }}" class="btn btn-outline-danger">
                    <i class="bi bi-x-lg"></i>
                </a>
            {% endif %}
        </form>
    </div>

    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nom / Société</th>
                        <th>Email</th>
                        <th>Téléphone</th>
                        <th>Ville</th>
                        <th class="text-center">Projets</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for client in clients %}
                    <tr>
                        <td>
                            <div class="fw-semibold">
                                <a href="{{ path('app_client_show', {id: client.id}) }}" class="text-decoration-none text-dark">
                                    {{ client.displayName }}
                                </a>
                            </div>
                            {% if client.societe and client.prenom %}
                                <small class="text-muted">{{ client.prenom }} {{ client.nom }}</small>
                            {% endif %}
                        </td>
                        <td>
                            <a href="mailto:{{ client.email }}" class="text-decoration-none text-muted">
                                {{ client.email }}
                            </a>
                        </td>
                        <td>{{ client.telephone ?? '—' }}</td>
                        <td>
                            {% if client.codePostal or client.ville %}
                                {{ client.codePostal }} {{ client.ville }}
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary rounded-pill">{{ client.projects|length }}</span>
                        </td>
                        <td class="text-end">
                            <a href="{{ path('app_client_show', {id: client.id}) }}"
                               class="btn btn-sm btn-outline-secondary" title="Voir">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('app_client_edit', {id: client.id}) }}"
                               class="btn btn-sm btn-outline-primary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="POST"
                                  action="{{ path('app_client_delete', {id: client.id}) }}"
                                  class="d-inline">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete_client_' ~ client.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer"
                                        onclick="return confirm('Confirmer la suppression ?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center py-5 text-muted">
                            <i class="bi bi-people fs-2 d-block mb-2"></i>
                            Aucun client trouvé.
                            <a href="{{ path('app_client_new') }}" class="ms-2">Créer le premier client</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card-footer bg-white text-muted small py-2 px-3">
        {{ clients|length }} client{{ clients|length != 1 ? 's' : '' }} au total
    </div>
</div>
{% endblock %}
