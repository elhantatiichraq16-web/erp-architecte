{% extends 'base.html.twig' %}

{% block title %}{{ client.displayName }}{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_client_index') }}">Clients</a></li>
    <li class="breadcrumb-item active">{{ client.displayName }}</li>
{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_client_edit', {id: client.id}) }}" class="btn btn-outline-primary">
        <i class="bi bi-pencil me-1"></i> Modifier
    </a>
    <form method="POST" action="{{ path('app_client_delete', {id: client.id}) }}" class="d-inline">
        <input type="hidden" name="_token" value="{{ csrf_token('delete_client_' ~ client.id) }}">
        <button type="submit" class="btn btn-outline-danger"
                onclick="return confirm('Confirmer la suppression ?')">
            <i class="bi bi-trash me-1"></i> Supprimer
        </button>
    </form>
{% endblock %}

{% block body %}
<div class="row g-4">
    {# ── Left column: client card ── #}
    <div class="col-lg-4">
        <div class="card rounded-4 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="bg-primary bg-opacity-10 rounded-circle d-inline-flex align-items-center
                            justify-content-center mb-3" style="width:72px;height:72px;">
                    <i class="bi bi-person-fill fs-2 text-primary"></i>
                </div>
                <h4 class="fw-bold mb-0">{{ client.displayName }}</h4>
                {% if client.societe %}
                    <p class="text-muted mb-0">{{ client.prenom }} {{ client.nom }}</p>
                {% endif %}
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="text-muted"><i class="bi bi-envelope me-2"></i>Email</span>
                    <a href="mailto:{{ client.email }}" class="text-decoration-none">{{ client.email }}</a>
                </li>
                {% if client.telephone %}
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="text-muted"><i class="bi bi-telephone me-2"></i>Téléphone</span>
                    <span>{{ client.telephone }}</span>
                </li>
                {% endif %}
                {% if client.adresse %}
                <li class="list-group-item">
                    <div class="text-muted mb-1"><i class="bi bi-geo-alt me-2"></i>Adresse</div>
                    <div>{{ client.adresse }}<br>{{ client.codePostal }} {{ client.ville }}</div>
                </li>
                {% endif %}
                {% if client.siret %}
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="text-muted"><i class="bi bi-card-text me-2"></i>SIRET</span>
                    <span class="font-monospace">{{ client.siret }}</span>
                </li>
                {% endif %}
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span class="text-muted"><i class="bi bi-calendar me-2"></i>Client depuis</span>
                    <span>{{ client.createdAt|date('d/m/Y') }}</span>
                </li>
            </ul>
        </div>

        {% if client.notes %}
        <div class="card rounded-4 shadow-sm mt-3">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-sticky me-2 text-warning"></i>Notes
            </div>
            <div class="card-body">
                <p class="mb-0 text-muted" style="white-space:pre-wrap;">{{ client.notes }}</p>
            </div>
        </div>
        {% endif %}
    </div>

    {# ── Right column: tabs ── #}
    <div class="col-lg-8">
        <ul class="nav nav-tabs mb-3" id="clientTabs" role="tablist">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-projects">
                    <i class="bi bi-folder me-1"></i> Projets
                    <span class="badge bg-primary ms-1">{{ client.projects|length }}</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-quotes">
                    <i class="bi bi-file-text me-1"></i> Devis
                    <span class="badge bg-secondary ms-1">{{ client.quotes|length }}</span>
                </button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-invoices">
                    <i class="bi bi-receipt me-1"></i> Factures
                    <span class="badge bg-secondary ms-1">{{ client.invoices|length }}</span>
                </button>
            </li>
        </ul>

        <div class="tab-content">
            {# Projects tab #}
            <div class="tab-pane fade show active" id="tab-projects">
                <div class="card rounded-4 shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Référence</th>
                                        <th>Nom</th>
                                        <th>Statut</th>
                                        <th>Avancement</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for project in client.projects %}
                                    <tr>
                                        <td><span class="font-monospace">{{ project.reference }}</span></td>
                                        <td>
                                            <a href="{{ path('app_project_show', {id: project.id}) }}"
                                               class="text-decoration-none fw-semibold text-dark">
                                                {{ project.nom }}
                                            </a>
                                        </td>
                                        <td>
                                            <span class="badge {{ project.statutBadgeClass }}">
                                                {{ project.statutLabel }}
                                            </span>
                                        </td>
                                        <td style="min-width:100px;">
                                            <div class="progress" style="height:6px;">
                                                <div class="progress-bar bg-primary"
                                                     style="width:{{ project.avancementGlobal }}%"></div>
                                            </div>
                                            <small class="text-muted">{{ project.avancementGlobal }}%</small>
                                        </td>
                                        <td class="text-end">
                                            <a href="{{ path('app_project_show', {id: project.id}) }}"
                                               class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">Aucun projet.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            {# Quotes tab #}
            <div class="tab-pane fade" id="tab-quotes">
                <div class="card rounded-4 shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Numéro</th>
                                        <th>Objet</th>
                                        <th>Date</th>
                                        <th>Statut</th>
                                        <th class="text-end">Total TTC</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for quote in client.quotes %}
                                    <tr>
                                        <td><span class="font-monospace">{{ quote.numero }}</span></td>
                                        <td>{{ quote.objet }}</td>
                                        <td>{{ quote.dateCreation|date('d/m/Y') }}</td>
                                        <td>
                                            <span class="badge {{ quote.statutBadgeClass }}">
                                                {{ quote.statutLabel }}
                                            </span>
                                        </td>
                                        <td class="text-end fw-semibold">
                                            {{ quote.totalTTC|number_format(2, ',', '.') }} €
                                        </td>
                                        <td class="text-end">
                                            <a href="{{ path('app_quote_show', {id: quote.id}) }}"
                                               class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">Aucun devis.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            {# Invoices tab #}
            <div class="tab-pane fade" id="tab-invoices">
                <div class="card rounded-4 shadow-sm">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Numéro</th>
                                        <th>Objet</th>
                                        <th>Émission</th>
                                        <th>Statut</th>
                                        <th class="text-end">Total TTC</th>
                                        <th class="text-end">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                {% for invoice in client.invoices %}
                                    <tr>
                                        <td><span class="font-monospace">{{ invoice.numero }}</span></td>
                                        <td>{{ invoice.objet }}</td>
                                        <td>{{ invoice.dateEmission|date('d/m/Y') }}</td>
                                        <td>
                                            <span class="badge {{ invoice.statutBadgeClass }}">
                                                {{ invoice.statutLabel }}
                                            </span>
                                        </td>
                                        <td class="text-end fw-semibold">
                                            {{ invoice.totalTTC|number_format(2, ',', '.') }} €
                                        </td>
                                        <td class="text-end">
                                            <a href="{{ path('app_invoice_show', {id: invoice.id}) }}"
                                               class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </td>
                                    </tr>
                                {% else %}
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">Aucune facture.</td>
                                    </tr>
                                {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>{# /tab-content #}
    </div>
</div>
{% endblock %}
