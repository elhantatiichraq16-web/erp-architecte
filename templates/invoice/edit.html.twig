{% extends 'base.html.twig' %}

{% block title %}Modifier facture — {{ invoice.numero }}{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_invoice_index') }}">Factures</a></li>
    <li class="breadcrumb-item">
        <a href="{{ path('app_invoice_show', {id: invoice.id}) }}">{{ invoice.numero }}</a>
    </li>
    <li class="breadcrumb-item active">Modifier</li>
{% endblock %}

{% block body %}
<div class="card rounded-4 shadow-sm">
    <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
        <h5 class="mb-0 fw-semibold">
            <i class="bi bi-pencil me-2 text-primary"></i> Modifier facture — {{ invoice.numero }}
        </h5>
        <div class="d-flex gap-2">
            <a href="{{ path('app_invoice_print', {id: invoice.id}) }}"
               class="btn btn-sm btn-outline-dark" target="_blank">
                <i class="bi bi-printer me-1"></i> Imprimer
            </a>
            <a href="{{ path('app_invoice_show', {id: invoice.id}) }}"
               class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-eye me-1"></i> Voir
            </a>
        </div>
    </div>
    <div class="card-body p-4">
        {% include 'invoice/_form.html.twig' %}
    </div>
    <div class="card-footer bg-white border-top d-flex justify-content-between py-3 px-4">
        <a href="{{ path('app_invoice_show', {id: invoice.id}) }}" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i> Annuler
        </a>
        <button type="submit" form="invoice-form" class="btn btn-primary">
            <i class="bi bi-check-lg me-1"></i> Enregistrer les modifications
        </button>
    </div>
</div>
{% endblock %}
