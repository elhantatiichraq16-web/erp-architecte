{% extends 'base.html.twig' %}

{% block title %}Factures{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active">Factures</li>
{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_invoice_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Nouvelle facture
    </a>
{% endblock %}

{% block body %}
<div class="card rounded-4 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Numéro</th>
                        <th>Client</th>
                        <th>Objet</th>
                        <th>Date émission</th>
                        <th>Échéance</th>
                        <th>Statut</th>
                        <th class="text-end">Total TTC</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for invoice in invoices %}
                    <tr class="{{ invoice.enRetard ? 'table-danger' : '' }}">
                        <td>
                            <a href="{{ path('app_invoice_show', {id: invoice.id}) }}"
                               class="font-monospace text-decoration-none fw-semibold text-dark">
                                {{ invoice.numero }}
                            </a>
                        </td>
                        <td>
                            <a href="{{ path('app_client_show', {id: invoice.client.id}) }}"
                               class="text-decoration-none text-muted">
                                {{ invoice.client.displayName }}
                            </a>
                        </td>
                        <td>{{ invoice.objet }}</td>
                        <td>{{ invoice.dateEmission|date('d/m/Y') }}</td>
                        <td>
                            {% if invoice.dateEcheance %}
                                <span class="{{ invoice.enRetard ? 'text-danger fw-semibold' : '' }}">
                                    {{ invoice.dateEcheance|date('d/m/Y') }}
                                </span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge {{ invoice.statutBadgeClass }}">
                                {{ invoice.statutLabel }}
                            </span>
                        </td>
                        <td class="text-end fw-semibold">
                            {{ invoice.totalTTC|number_format(2, ',', '.') }} €
                        </td>
                        <td class="text-end">
                            <a href="{{ path('app_invoice_show', {id: invoice.id}) }}"
                               class="btn btn-sm btn-outline-secondary" title="Voir">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('app_invoice_print', {id: invoice.id}) }}"
                               class="btn btn-sm btn-outline-dark" title="Imprimer" target="_blank">
                                <i class="bi bi-printer"></i>
                            </a>
                            <a href="{{ path('app_invoice_edit', {id: invoice.id}) }}"
                               class="btn btn-sm btn-outline-primary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            {% if invoice.statut != 'payee' %}
                                <a href="{{ path('app_invoice_pay', {id: invoice.id}) }}"
                                   class="btn btn-sm btn-success" title="Marquer payée">
                                    <i class="bi bi-check-circle me-1"></i>Payer
                                </a>
                            {% endif %}
                            <form method="POST"
                                  action="{{ path('app_invoice_delete', {id: invoice.id}) }}"
                                  class="d-inline">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete_invoice_' ~ invoice.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer"
                                        onclick="return confirm('Confirmer la suppression ?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="bi bi-receipt fs-2 d-block mb-2"></i>
                            Aucune facture trouvée.
                            <a href="{{ path('app_invoice_new') }}" class="ms-2">Créer la première facture</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <div class="card-footer bg-white text-muted small py-2 px-3">
        {{ invoices|length }} facture{{ invoices|length != 1 ? 's' : '' }} au total
    </div>
</div>
{% endblock %}
