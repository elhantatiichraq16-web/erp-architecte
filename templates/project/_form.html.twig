{{ form_start(form, {attr: {novalidate: 'novalidate', class: 'needs-validation'}}) }}

<div class="row g-3">
    {# General Info #}
    <div class="col-12">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3">
            <i class="bi bi-folder me-1"></i> Informations générales
        </h6>
    </div>

    <div class="col-md-8">
        {{ form_label(form.nom, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.nom, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.nom) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.statut, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.statut, {attr: {class: 'form-select'}}) }}
        {{ form_errors(form.statut) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.client, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.client, {attr: {class: 'form-select'}}) }}
        {{ form_errors(form.client) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.couleur, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        <div class="input-group">
            {{ form_widget(form.couleur, {attr: {class: 'form-control form-control-color', type: 'color'}}) }}
            <span class="input-group-text">Couleur du projet</span>
        </div>
        {{ form_errors(form.couleur) }}
    </div>

    {# Location #}
    <div class="col-12 mt-2">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3">
            <i class="bi bi-geo-alt me-1"></i> Chantier
        </h6>
    </div>

    <div class="col-md-8">
        {{ form_label(form.adresseChantier, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.adresseChantier, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.adresseChantier) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.surface, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        <div class="input-group">
            {{ form_widget(form.surface, {attr: {class: 'form-control'}}) }}
            <span class="input-group-text">m²</span>
        </div>
        {{ form_errors(form.surface) }}
    </div>

    {# Dates #}
    <div class="col-12 mt-2">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3">
            <i class="bi bi-calendar me-1"></i> Planification
        </h6>
    </div>

    <div class="col-md-6">
        {{ form_label(form.dateDebut, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.dateDebut, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.dateDebut) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.dateFinPrevisionnelle, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.dateFinPrevisionnelle, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.dateFinPrevisionnelle) }}
    </div>

    {# Budget #}
    <div class="col-12 mt-2">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3">
            <i class="bi bi-cash me-1"></i> Budget
        </h6>
    </div>

    <div class="col-md-6">
        {{ form_label(form.montantHonoraires, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        <div class="input-group">
            {{ form_widget(form.montantHonoraires, {attr: {class: 'form-control'}}) }}
            <span class="input-group-text">€</span>
        </div>
        {{ form_errors(form.montantHonoraires) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.budgetPrevisionnel, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        <div class="input-group">
            {{ form_widget(form.budgetPrevisionnel, {attr: {class: 'form-control'}}) }}
            <span class="input-group-text">€</span>
        </div>
        {{ form_errors(form.budgetPrevisionnel) }}
    </div>

    {# Collaborators #}
    {% if form.collaborators is defined %}
    <div class="col-12 mt-2">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3">
            <i class="bi bi-people me-1"></i> Équipe
        </h6>
    </div>
    <div class="col-12">
        {{ form_label(form.collaborators, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.collaborators, {attr: {class: 'form-select', multiple: 'multiple', size: '5'}}) }}
        {{ form_errors(form.collaborators) }}
        <div class="form-text">Maintenez Ctrl pour sélectionner plusieurs collaborateurs.</div>
    </div>
    {% endif %}

    {# Notes #}
    <div class="col-12 mt-2">
        {{ form_label(form.notes, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.notes, {attr: {class: 'form-control', rows: 4}}) }}
        {{ form_errors(form.notes) }}
    </div>

    {# Phases collection #}
    {% if form.phases is defined %}
    <div class="col-12 mt-2">
        <h6 class="text-uppercase text-muted fw-semibold small mb-3">
            <i class="bi bi-list-check me-1"></i> Phases du projet
        </h6>
        <div id="phases-collection"
             data-prototype="{{ form_widget(form.phases.vars.prototype)|e('html_attr') }}">
            {% for phase in form.phases %}
                <div class="phase-item border rounded-3 p-3 mb-2 bg-light">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-5">
                            {{ form_label(phase.nom, null, {label_attr: {class: 'form-label small fw-semibold'}}) }}
                            {{ form_widget(phase.nom, {attr: {class: 'form-control form-control-sm'}}) }}
                        </div>
                        <div class="col-md-4">
                            {{ form_label(phase.description, null, {label_attr: {class: 'form-label small fw-semibold'}}) }}
                            {{ form_widget(phase.description, {attr: {class: 'form-control form-control-sm'}}) }}
                        </div>
                        <div class="col-md-2">
                            {{ form_label(phase.avancement, null, {label_attr: {class: 'form-label small fw-semibold'}}) }}
                            <div class="input-group input-group-sm">
                                {{ form_widget(phase.avancement, {attr: {class: 'form-control form-control-sm', min: '0', max: '100'}}) }}
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-md-1 text-end">
                            <button type="button" class="btn btn-sm btn-outline-danger remove-phase">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
        <button type="button" id="add-phase" class="btn btn-sm btn-outline-primary mt-2">
            <i class="bi bi-plus-lg me-1"></i> Ajouter une phase
        </button>
    </div>
    {% endif %}
</div>

{{ form_end(form) }}

{% if form.phases is defined %}
<script>
(function () {
    const container = document.getElementById('phases-collection');
    const proto     = container.dataset.prototype;
    let   idx       = container.querySelectorAll('.phase-item').length;

    document.getElementById('add-phase').addEventListener('click', function () {
        const html = proto.replace(/__name__/g, idx++);
        const div  = document.createElement('div');
        div.classList.add('phase-item', 'border', 'rounded-3', 'p-3', 'mb-2', 'bg-light');
        div.innerHTML = `<div class="row g-2 align-items-end">${html}<div class="col-md-1 text-end"><button type="button" class="btn btn-sm btn-outline-danger remove-phase"><i class="bi bi-trash"></i></button></div></div>`;
        container.appendChild(div);
    });

    document.addEventListener('click', function (e) {
        if (e.target.closest('.remove-phase')) {
            e.target.closest('.phase-item').remove();
        }
    });
}());
</script>
{% endif %}
