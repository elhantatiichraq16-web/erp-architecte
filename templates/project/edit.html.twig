{% extends 'base.html.twig' %}

{% block title %}Modifier projet — {{ project.reference }}{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ path('app_project_index') }}">Projets</a></li>
    <li class="breadcrumb-item">
        <a href="{{ path('app_project_show', {id: project.id}) }}">{{ project.reference }}</a>
    </li>
    <li class="breadcrumb-item active">Modifier</li>
{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-xl-9">
        <div class="card rounded-4 shadow-sm">
            <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-pencil me-2 text-primary"></i> Modifier — {{ project.reference }} · {{ project.nom }}
                </h5>
                <a href="{{ path('app_project_show', {id: project.id}) }}" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-eye me-1"></i> Voir
                </a>
            </div>
            <div class="card-body p-4">
                {% include 'project/_form.html.twig' %}
            </div>
            <div class="card-footer bg-white border-top d-flex justify-content-between py-3 px-4">
                <a href="{{ path('app_project_show', {id: project.id}) }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left me-1"></i> Annuler
                </a>
                <button type="submit" form="{{ form.vars.id }}" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i> Enregistrer les modifications
                </button>
            </div>
        </div>
    </div>
</div>
{% endblock %}
