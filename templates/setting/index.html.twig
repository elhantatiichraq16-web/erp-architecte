{% extends 'base.html.twig' %}

{% block title %}Paramètres{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active">Paramètres</li>
{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_setting_export') }}" class="btn btn-outline-secondary">
        <i class="bi bi-download me-1"></i> Exporter JSON
    </a>
{% endblock %}

{% block body %}

{# Group keys into sections #}
{% set cabinetKeys = ['company_name','company_address','company_city','company_zip',
                      'company_phone','company_email','company_siret','company_tva_number'] %}
{% set facturationKeys = ['default_tva_rate','invoice_prefix','quote_prefix',
                          'invoice_footer','quote_footer','currency','date_format'] %}

{{ form_start(form, {attr: {novalidate: 'novalidate', id: 'settings-form'}}) }}

<div class="row g-4">

    {# ── Cabinet info ── #}
    <div class="col-lg-6">
        <div class="card rounded-4 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-building me-2 text-primary"></i> Informations du cabinet
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    {% for cle in cabinetKeys %}
                        {% if form[cle] is defined %}
                        <div class="col-12">
                            {{ form_label(form[cle], null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                            {{ form_widget(form[cle]) }}
                            {% if defaults[cle] is defined and defaults[cle].description is defined %}
                                <div class="form-text text-muted">{{ defaults[cle].description }}</div>
                            {% endif %}
                            {{ form_errors(form[cle]) }}
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>

    {# ── Facturation ── #}
    <div class="col-lg-6">
        <div class="card rounded-4 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 fw-semibold">
                    <i class="bi bi-receipt me-2 text-success"></i> Facturation
                </h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    {% for cle in facturationKeys %}
                        {% if form[cle] is defined %}
                        <div class="col-12">
                            {{ form_label(form[cle], null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                            {% if cle == 'default_tva_rate' %}
                                <div class="input-group">
                                    {{ form_widget(form[cle]) }}
                                    <span class="input-group-text">%</span>
                                </div>
                            {% elseif cle == 'invoice_prefix' or cle == 'quote_prefix' %}
                                <div class="input-group">
                                    {{ form_widget(form[cle]) }}
                                    <span class="input-group-text text-muted">-AAAA-NNN</span>
                                </div>
                            {% else %}
                                {{ form_widget(form[cle]) }}
                            {% endif %}
                            {% if defaults[cle] is defined and defaults[cle].description is defined %}
                                <div class="form-text text-muted">{{ defaults[cle].description }}</div>
                            {% endif %}
                            {{ form_errors(form[cle]) }}
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        </div>

        {# Reset card #}
        <div class="card rounded-4 shadow-sm mt-4 border-warning">
            <div class="card-header bg-warning bg-opacity-10 py-3">
                <h5 class="mb-0 fw-semibold text-warning">
                    <i class="bi bi-exclamation-triangle me-2"></i> Zone de danger
                </h5>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-3">
                    Réinitialiser tous les paramètres à leurs valeurs par défaut.
                    Cette action est irréversible.
                </p>
                <form method="POST" action="{{ path('app_setting_reset') }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('reset_settings') }}">
                    <button type="submit" class="btn btn-outline-warning"
                            onclick="return confirm('Réinitialiser tous les paramètres aux valeurs par défaut ?')">
                        <i class="bi bi-arrow-counterclockwise me-2"></i> Réinitialiser les paramètres
                    </button>
                </form>
            </div>
        </div>
    </div>

    {# ── Save bar ── #}
    <div class="col-12">
        <div class="card rounded-4 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center py-3 px-4">
                <span class="text-muted small">
                    <i class="bi bi-info-circle me-1"></i>
                    Les paramètres s'appliquent à toute l'application.
                </span>
                <div class="d-flex gap-2">
                    <a href="{{ path('app_setting_export') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-download me-1"></i> Exporter JSON
                    </a>
                    {{ form_widget(form.submit) }}
                </div>
            </div>
        </div>
    </div>

</div>

{{ form_end(form) }}

{% endblock %}
