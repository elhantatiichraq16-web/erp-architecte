{{ form_start(form, {attr: {novalidate: 'novalidate', class: 'needs-validation'}}) }}

<div class="row g-3">
    <div class="col-md-6">
        {{ form_label(form.collaborator, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.collaborator, {attr: {class: 'form-select'}}) }}
        {{ form_errors(form.collaborator) }}
    </div>

    <div class="col-md-6">
        {{ form_label(form.project, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.project, {attr: {class: 'form-select'}}) }}
        {{ form_errors(form.project) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.date, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.date, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.date) }}
    </div>

    <div class="col-md-2">
        {{ form_label(form.heures, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        <div class="input-group">
            {{ form_widget(form.heures, {attr: {class: 'form-control', step: '0.25', min: '0', max: '24'}}) }}
            <span class="input-group-text">h</span>
        </div>
        {{ form_errors(form.heures) }}
    </div>

    <div class="col-md-4">
        {{ form_label(form.phase, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.phase, {attr: {class: 'form-control'}}) }}
        {{ form_errors(form.phase) }}
    </div>

    <div class="col-md-2 d-flex align-items-end">
        <div class="form-check form-switch mb-2">
            {{ form_widget(form.facturable, {attr: {class: 'form-check-input', role: 'switch', id: 'facturable-toggle'}}) }}
            {{ form_label(form.facturable, null, {label_attr: {class: 'form-check-label fw-semibold', for: 'facturable-toggle'}}) }}
        </div>
    </div>

    <div class="col-12">
        {{ form_label(form.description, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
        {{ form_widget(form.description, {attr: {class: 'form-control', rows: 3}}) }}
        {{ form_errors(form.description) }}
    </div>
</div>

{{ form_end(form) }}
