{% extends 'base.html.twig' %}

{% block title %}Saisies de temps{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item active">Saisies de temps</li>
{% endblock %}

{% block page_actions %}
    <a href="{{ path('app_time_rapport') }}" class="btn btn-outline-secondary">
        <i class="bi bi-bar-chart me-1"></i> Rapport
    </a>
    <a href="{{ path('app_time_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i> Nouvelle saisie
    </a>
{% endblock %}

{% block body %}
<div class="card rounded-4 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Date</th>
                        <th>Collaborateur</th>
                        <th>Projet</th>
                        <th>Phase</th>
                        <th class="text-end">Heures</th>
                        <th>Description</th>
                        <th class="text-center">Facturable</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for entry in entries %}
                    <tr>
                        <td>{{ entry.date|date('d/m/Y') }}</td>
                        <td>
                            <span class="fw-semibold">{{ entry.collaborator }}</span>
                        </td>
                        <td>
                            <a href="{{ path('app_project_show', {id: entry.project.id}) }}"
                               class="text-decoration-none text-muted">
                                {{ entry.project.reference }}
                            </a>
                        </td>
                        <td>
                            {% if entry.phase %}
                                <span class="badge bg-light text-dark border">{{ entry.phase }}</span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="text-end fw-semibold">{{ entry.heures|number_format(2, ',', '.') }} h</td>
                        <td class="text-muted">{{ entry.description ?? '—' }}</td>
                        <td class="text-center">
                            {% if entry.facturable %}
                                <i class="bi bi-check-circle-fill text-success fs-5"></i>
                            {% else %}
                                <i class="bi bi-x-circle text-muted fs-5"></i>
                            {% endif %}
                        </td>
                        <td class="text-end">
                            <a href="{{ path('app_time_edit', {id: entry.id}) }}"
                               class="btn btn-sm btn-outline-primary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="POST"
                                  action="{{ path('app_time_delete', {id: entry.id}) }}"
                                  class="d-inline">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete_time_entry_' ~ entry.id) }}">
                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Supprimer"
                                        onclick="return confirm('Confirmer la suppression ?')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="bi bi-clock fs-2 d-block mb-2"></i>
                            Aucune saisie de temps.
                            <a href="{{ path('app_time_new') }}" class="ms-2">Créer la première saisie</a>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
                {% if entries|length > 0 %}
                <tfoot class="table-light">
                    {% set total = 0 %}
                    {% for entry in entries %}
                        {% set total = total + entry.heures %}
                    {% endfor %}
                    <tr>
                        <td colspan="4" class="fw-semibold">Total</td>
                        <td class="text-end fw-bold">{{ total|number_format(2, ',', '.') }} h</td>
                        <td colspan="3"></td>
                    </tr>
                </tfoot>
                {% endif %}
            </table>
        </div>
    </div>
    <div class="card-footer bg-white text-muted small py-2 px-3">
        {{ entries|length }} saisie{{ entries|length != 1 ? 's' : '' }} au total
    </div>
</div>
{% endblock %}
